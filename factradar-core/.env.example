# --- LLM backend (FR-LLM): ollama = free/local, openai / claude = paid APIs ---
LLM_BACKEND=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Free/local alternative:
# LLM_BACKEND=ollama
# OLLAMA_MODEL=llama3.1
# OLLAMA_URL=http://localhost:11434

# Or Claude (note: this is the API, billed separately from any Claude.ai subscription):
# LLM_BACKEND=claude
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- Output (FR-OUT-01): the single chat/group that receives verdicts ---
# "me" = the linked account's own "Message Yourself" chat (sender never sees it).
# Or a specific JID: discover via ingest logs ("message received chat_id=...").
# Group JIDs end in @g.us, individual numbers in @s.whatsapp.net
OUTPUT_JID=me

# Only send verdicts at/above this confidence; below it, label is set to Unverified
CONFIDENCE_GATE=60

# Where the ingest service is reachable (local default below; on Railway use its internal URL)
INGEST_URL=http://localhost:41734

# Optional: free Google Fact Check Tools API key (improves accuracy a lot)
# FACTCHECK_API_KEY=

# --- MongoDB audit trail (best-effort; leave blank to disable) ---
# URL-encode special chars in the password (e.g. '@' becomes %40).
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?appName=APP
MONGODB_DB=factradar

# --- Media stage (image OCR + audio/video transcription) ---
# faster-whisper model: tiny | base | small | medium (bigger = better + slower)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8
# Frames sampled from each video for on-screen-text OCR (0 disables frame OCR)
VIDEO_OCR_FRAMES=3
# Only needed if the binaries aren't on PATH:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# FFMPEG_CMD=C:\ffmpeg\bin\ffmpeg.exe
