PORT=41900
LOG_LEVEL=info

# Public website URL — admin pages link back here ("Back to FactRadar").
SITE_URL=http://localhost:41734

# The ONLY thing protecting the admin console — set a strong, unique password.
ADMIN_PASSWORD=change-me-to-something-strong

# Shares the same audit database as ingest + core.
# URL-encode special chars in the password (e.g. '@' becomes %40).
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?appName=APP
MONGODB_DB=factradar
