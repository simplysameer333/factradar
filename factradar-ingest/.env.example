PORT=41734

# IMPORTANT (Railway): point this at a mounted Volume so the WhatsApp session
# survives redeploys. Otherwise users must re-scan the QR every deploy.
AUTH_DIR=/data/auth

# URL of factradar-core. Locally: http://localhost:41820
# On Railway: use the core service's private/internal URL.
CORE_URL=http://localhost:41820

# Optional: link by pairing code instead of QR (E.164 digits, NO leading '+').
# Example for a UK number +44 7700 900000:
# PAIRING_NUMBER=447700900000

# Skip media larger than this many bytes (caption still forwarded). Default 20 MB.
MAX_MEDIA_BYTES=20971520

# Fact-check plain text messages too? Default false: only image/video/voice-note
# messages are checked (text volume in busy groups is huge).
PROCESS_TEXT=false

LOG_LEVEL=info

# Public URL of the admin console (the header "Admin login" link points here).
ADMIN_URL=http://localhost:41900

# --- MongoDB audit trail (best-effort; leave blank to disable) ---
# URL-encode special chars in the password (e.g. '@' becomes %40).
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?appName=APP
MONGODB_DB=factradar
